{
  "name": "honiara-taxi-network",
  "version": "1.0.0",
  "description": "Honiara Taxi Network — MereSimi Studios Ltd",
  "private": true,
  "scripts": {
    "dev":            "vite",
    "build":          "tsc && vite build",
    "preview":        "vite preview",
    "type-check":     "tsc --noEmit",
    "lint":           "eslint src --ext ts,tsx --max-warnings 0",
    "cap:sync":       "npm run build && npx cap sync",
    "cap:android":    "npm run build && npx cap sync android && npx cap open android",
    "cap:ios":        "npm run build && npx cap sync ios && npx cap open ios",
    "electron:dev":   "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron electron/main.js\"",
    "electron:build": "npm run build && electron-builder",
    "sb:types":       "supabase gen types typescript --linked > src/types/database.ts",
    "sb:push":        "supabase db push",
    "sb:reset":       "supabase db reset"
  },
  "dependencies": {
    "@capacitor/android":           "^5.7.0",
    "@capacitor/app":               "^5.0.7",
    "@capacitor/core":              "^5.7.0",
    "@capacitor/geolocation":       "^5.0.7",
    "@capacitor/haptics":           "^5.0.7",
    "@capacitor/ios":               "^5.7.0",
    "@capacitor/push-notifications":"^5.1.2",
    "@capacitor/status-bar":        "^5.0.7",
    "@googlemaps/js-api-loader":    "^1.16.6",
    "@supabase/supabase-js":        "^2.43.0",
    "@tanstack/react-query":        "^5.40.0",
    "@tanstack/react-query-devtools":"^5.40.0",
    "@vis.gl/react-google-maps":    "^1.1.0",
    "clsx":                         "^2.1.1",
    "date-fns":                     "^3.6.0",
    "firebase":                     "^10.12.0",
    "react":                        "^18.3.1",
    "react-dom":                    "^18.3.1",
    "tailwind-merge":               "^2.3.0",
    "zustand":                      "^4.5.2"
  },
  "devDependencies": {
    "@types/google.maps":                   "^3.55.9",
    "@types/node":                          "^20.14.0",
    "@types/react":                         "^18.3.3",
    "@types/react-dom":                     "^18.3.0",
    "@typescript-eslint/eslint-plugin":     "^7.13.0",
    "@typescript-eslint/parser":            "^7.13.0",
    "@vitejs/plugin-react":                 "^4.3.1",
    "autoprefixer":                         "^10.4.19",
    "concurrently":                         "^8.2.2",
    "electron":                             "^28.3.3",
    "electron-builder":                     "^24.13.3",
    "eslint":                               "^8.57.0",
    "eslint-plugin-react-hooks":            "^4.6.2",
    "eslint-plugin-react-refresh":          "^0.4.7",
    "postcss":                              "^8.4.39",
    "tailwindcss":                          "^3.4.4",
    "typescript":                           "^5.4.5",
    "vite":                                 "^5.3.1",
    "wait-on":                              "^7.2.0"
  }
}
