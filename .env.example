# ============================================================
# HONIARA TAXI NETWORK — Environment Variables
# MereSimi Studios Ltd
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://rhdqakmgrsvvqfgmzcjw.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-settings-api

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase (get from Firebase Console → Project Settings → Your Apps → Web)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_VAPID_KEY=your-vapid-key-for-web-push

# App Config
VITE_APP_NAME=Honiara Taxi Network
VITE_APP_VERSION=1.0.0
VITE_COMPANY_NAME=MereSimi Studios Ltd

# Honiara region bounds (do not change unless expanding service area)
VITE_MAP_CENTER_LAT=-9.4333
VITE_MAP_CENTER_LNG=160.0520
VITE_MAP_DEFAULT_ZOOM=13
VITE_SERVICE_RADIUS_KM=30

# Subscription pricing (SBD)
VITE_CUSTOMER_SUB_PRICE=20
VITE_VEHICLE_SUB_PRICE=20

# GPS transmission interval (milliseconds)
VITE_GPS_INTERVAL_MS=20000

# Booking dispatch timeout (milliseconds)
VITE_DISPATCH_TIMEOUT_MS=30000
